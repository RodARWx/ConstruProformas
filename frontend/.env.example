# URL base del API de Construproformas.
# Desarrollo local (con proxy Vite): /api
# Producción Cloudflare + Railway (dominio sin https ni /api; el build los añade):
#   construproformas-api-production.up.railway.app
# Forma explícita también válida:
#   https://construproformas-api-production.up.railway.app/api
VITE_API_BASE_URL=/api
VITE_API_KEY=construproformas-dev-key

# PIN de acceso del lado del cliente (no es autenticación de backend)
VITE_ACCESS_PIN=2585
